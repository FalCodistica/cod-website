# Notion — used to log every form submission as a row in a database.
# 1. Create an internal integration at https://www.notion.so/my-integrations
# 2. Share the "Website Form Submissions" database with that integration
# 3. Copy the integration's secret below
NOTION_API_KEY=
# The data source ID for the "Website Form Submissions" database (see the
# `collection://<id>` URL shown when the database was created/fetched).
NOTION_SUBMISSIONS_DATA_SOURCE_ID=

# Resend — used to email the team a notification for every submission
# (and, for the Join the Team form, the applicant's CV as an attachment).
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Must be an address on a domain verified in Resend, e.g. "Codistica <hello@codistica.com>"
RESEND_FROM_EMAIL=
# Inbox that should receive new-submission notifications
NOTIFICATION_EMAIL=
